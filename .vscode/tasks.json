{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Create Subfolder",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/C",
                "if not exist \"${workspaceFolder}\\build\\${fileBasenameNoExtension}\" mkdir \"${workspaceFolder}\\build\\${fileBasenameNoExtension}\""
            ],
            "presentation": {
                "reveal": "silent",
                "close": true
            }
        },
        {
            "type": "cppbuild",
            "label": "Build with MSVC",
            "command": "cl.exe",
            "args": [
                "/nologo",
                "/Zi",
                "/EHsc",
                "/I", "${workspaceFolder}/include",
                "${file}",
                "/Fe:", "${workspaceFolder}/build/${fileBasenameNoExtension}/${fileBasenameNoExtension}.exe",
                "/Fo:", "${workspaceFolder}/build/${fileBasenameNoExtension}/",
                "/Fd:", "${workspaceFolder}/build/${fileBasenameNoExtension}/",
                "/link", "/INCREMENTAL:NO",
                "gdi32.lib"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": ["$msCompile"],
            "dependsOn": "Create Subfolder",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Biên dịch bằng MSVC compiler (cl.exe)"
        }
    ]
}